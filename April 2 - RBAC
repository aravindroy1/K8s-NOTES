## Step 3 — Create Role for Development

apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  namespace: team3-ns
  name: dev-role
rules:
- apiGroups: [""]
  resources: ["pods"]
  verbs: ["get","list","watch","create","delete"]

- apiGroups: ["apps"]
  resources: ["deployments"]
  verbs: ["get","list","watch","create","delete"]

---

## Step 4 — Bind Development Group

apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: dev-group-binding
  namespace: team3-ns
subjects:
- kind: Group
  name: development
  apiGroup: rbac.authorization.k8s.io
roleRef:
  kind: Role
  name: dev-role
  apiGroup: rbac.authorization.k8s.io

---

## Step 5 — Create Role for Testing

apiVersion: rbac.authorization.k8s.io/v1
kind: Role
metadata:
  namespace: team3-ns
  name: test-role
rules:
- apiGroups: [""]
  resources: ["services"]
  verbs: ["get","list","watch"]

---

## Step 6 — Bind Testing Group

apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: test-group-binding
  namespace: team3-ns
subjects:
- kind: Group
  name: testing
  apiGroup: rbac.authorization.k8s.io
roleRef:
  kind: Role
  name: test-role
  apiGroup: rbac.authorization.k8s.io

---

